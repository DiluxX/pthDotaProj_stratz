<SearchScreen>:
    name: "search"

    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: app.bg_color

        MDTopAppBar:
            title: "Поиск игрока"
            elevation: 4
            md_bg_color: app.accent_color
            left_action_items: [["star", lambda x: root.open_favorites()]]
            right_action_items: [["sword-cross", lambda x: root.open_heroes()], ["cog", lambda x: root.open_settings()]]

        MDBoxLayout:
            orientation: 'vertical'
            padding: "20dp"
            spacing: "15dp"

            MDLabel:
                text: "Введи SteamID, SteamID64 или ссылку на профиль Steam"
                theme_text_color: "Custom"
                text_color: app.secondary_text_color
                font_style: "Body2"
                size_hint_y: None
                height: "40dp"

            MDTextField:
                id: search_input
                hint_text: "Steam ID / SteamID64 / ссылка на профиль"
                mode: "rectangle"
                text_color_normal: app.text_color

            MDRaisedButton:
                text: "НАЙТИ ИГРОКА"
                pos_hint: {"center_x": .5}
                md_bg_color: app.accent_color
                on_release: root.start_search()

            Widget:
