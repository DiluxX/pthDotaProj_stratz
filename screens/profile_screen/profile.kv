<ProfileScreen>:
    name: "profile"
    
    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: 0.12, 0.12, 0.12, 1

        MDTopAppBar:
            title: "Профиль игрока"
            left_action_items: [["arrow-left", lambda x: root.go_back()]]
            elevation: 4
            md_bg_color: 0.22, 0.28, 0.17, 1

        MDBoxLayout:
            orientation: 'vertical'
            padding: "20dp"
            spacing: "15dp"

            # Карточка основной информации
            MDCard:
                orientation: 'vertical'
                padding: "15dp"
                size_hint: (1, None)
                height: "160dp"
                md_bg_color: 0.18, 0.18, 0.18, 1
                radius: [12, 12, 12, 12]
                elevation: 3

                MDLabel:
                    id: name_label
                    text: "Загрузка..."
                    font_style: "H5"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    halign: "center"

                MDLabel:
                    id: id_label
                    text: "Steam ID: "
                    font_style: "Subtitle1"
                    theme_text_color: "Custom"
                    text_color: 0.6, 0.6, 0.6, 1
                    halign: "center"

                MDLabel:
                    id: rank_label
                    text: "Ранг: "
                    font_style: "Button"
                    theme_text_color: "Custom"
                    text_color: 0.42, 0.55, 0.35, 1
                    halign: "center"

            # Карточка подробной статистики
            MDCard:
                orientation: 'vertical'
                padding: "15dp"
                spacing: "10dp"
                size_hint: (1, None)
                height: "180dp"
                md_bg_color: 0.18, 0.18, 0.18, 1
                radius: [12, 12, 12, 12]
                elevation: 3

                MDLabel:
                    id: matches_label
                    text: "Всего матчей: —"
                    font_style: "Subtitle1"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

                MDBoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: "45dp"
                    spacing: "5dp"

                    MDLabel:
                        id: winrate_text_label
                        text: "Винрейт: —"
                        font_style: "Body2"
                        theme_text_color: "Custom"
                        text_color: 0.8, 0.8, 0.8, 1

                    MDProgressBar:
                        id: winrate_progress
                        value: 0
                        max: 100
                        color: 0.42, 0.55, 0.35, 1 # Наш оливковый цвет для полосы

                MDLabel:
                    id: top_hero_label
                    text: "Лучший герой: —"
                    font_style: "Body1"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

            Widget: # Пружина