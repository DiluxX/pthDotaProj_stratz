<SplashScreen>:
    name: "splash"
    md_bg_color: app.bg_color

    MDBoxLayout:
        orientation: 'vertical'
        padding: "20dp"
        spacing: "20dp"
        alignment: "center"
        pos_hint: {"center_x": 0.5, "center_y": 0.5}

        Widget:
            size_hint_y: 0.3

        MDLabel:
            text: "DOTA 2 STATS"
            font_style: "H3"
            theme_text_color: "Custom"
            text_color: app.accent_color
            halign: "center"
            bold: True

        MDLabel:
            text: "Мобильный аналитик"
            font_style: "Subtitle1"
            theme_text_color: "Custom"
            text_color: app.secondary_text_color
            halign: "center"

        MDAnchorLayout:
            size_hint_y: None
            height: "100dp"
            MDSpinner:
                size_hint: None, None
                size: "48dp", "48dp"
                active: True
                palette: [app.accent_color]

        Widget:
            size_hint_y: 0.3
