<SettingsScreen>:
    name: "settings"

    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: 0.12, 0.12, 0.12, 1

        MDTopAppBar:
            title: "Настройки приложения"
            left_action_items: [["arrow-left", lambda x: root.go_back()]]
            elevation: 4
            md_bg_color: 0.22, 0.28, 0.17, 1

        MDBoxLayout:
            orientation: 'vertical'
            padding: "20dp"
            spacing: "15dp"

            MDLabel:
                text: "Steam Web API"
                font_style: "H6"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1

            MDLabel:
                text: "Нужен для загрузки профиля, если STRATZ недоступен. Получить: steamcommunity.com/dev/apikey"
                font_style: "Body2"
                theme_text_color: "Custom"
                text_color: 0.6, 0.6, 0.6, 1

            MDTextField:
                id: steam_key_input
                hint_text: "Steam API Key"
                mode: "rectangle"
                text_color_normal: 1, 1, 1, 1

            MDLabel:
                text: "STRATZ API"
                font_style: "H6"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1

            MDLabel:
                text: "Bearer-токен для свежих данных, ранга и винрейта. Получить: stratz.com -> Settings -> API"
                font_style: "Body2"
                theme_text_color: "Custom"
                text_color: 0.6, 0.6, 0.6, 1

            MDTextField:
                id: stratz_key_input
                hint_text: "STRATZ API Key"
                mode: "rectangle"
                text_color_normal: 1, 1, 1, 1

            MDRaisedButton:
                text: "СОХРАНИТЬ НАСТРОЙКИ"
                pos_hint: {"center_x": .5}
                md_bg_color: 0.22, 0.28, 0.17, 1
                on_release: root.save_settings()

            Widget:
