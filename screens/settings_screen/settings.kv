<SettingsScreen>:
    name: "settings"

    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: app.bg_color

        MDTopAppBar:
            title: "Настройки"
            left_action_items: [["arrow-left", lambda x: root.go_back()]]
            elevation: 4
            md_bg_color: app.accent_color

        ScrollView:
            MDBoxLayout:
                orientation: 'vertical'
                padding: "20dp"
                spacing: "15dp"
                size_hint_y: None
                height: self.minimum_height

                MDLabel:
                    text: "Тема оформления"
                    font_style: "H6"
                    theme_text_color: "Custom"
                    text_color: app.text_color

                MDBoxLayout:
                    size_hint_y: None
                    height: "44dp"
                    spacing: "8dp"

                    MDRaisedButton:
                        id: theme_btn_system
                        text: "СИСТЕМНАЯ"
                        size_hint_x: 1
                        on_release: root.set_theme("system")

                    MDRaisedButton:
                        id: theme_btn_purple
                        text: "ФИОЛЕТОВАЯ"
                        size_hint_x: 1
                        on_release: root.set_theme("purple")

                    MDRaisedButton:
                        id: theme_btn_light
                        text: "СВЕТЛАЯ"
                        size_hint_x: 1
                        on_release: root.set_theme("light")

                Widget:
                    size_hint_y: None
                    height: "20dp"